# Local development
ADMIN_TOKEN=change-this-admin-token
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Hidden studio — never link in public UI
ADMIN_PATH=/_studio-provenance-private

# Production admin (required before live commerce)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
ADMIN_ALLOWLIST_EMAILS=you@yourdomain.com
# Optional Clerk JWT custom claim: "email": "{{user.primary_email_address}}"
# Auth resolves email from session claims first, then the Clerk user profile.

# Future (not required yet)
# DATABASE_URL=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
